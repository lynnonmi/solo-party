VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# (선택) 구글 시트 Apps Script 웹 앱 URL — 관리자 화면에서도 설정 가능
VITE_GOOGLE_SHEETS_URL=

# 솔라피 SMS — Supabase Edge Function Secrets에 등록 (아래는 참고용, .env에 넣지 마세요)
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_SENDER=01012345678
# SOLAPI_SMS_SUBJECT=[김해린의 두번째 솔로파티] 승인 안내
# SOLAPI_SMS_TEXT=...
